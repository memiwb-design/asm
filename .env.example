# =============================================
# ASM MOLFETTA APP - Environment Configuration
# =============================================
# Copy this file to .env and fill in your real values
# NEVER commit .env to Git (it's already in .gitignore)

# Server
PORT=8080
NODE_ENV=development

# =============================================
# SMTP Email Configuration (Nodemailer)
# =============================================
# For Gmail: Enable 2FA, then create an App Password at:
# https://myaccount.google.com/apppasswords
#
# Option A: Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password

# Option B: Use any SMTP service (SendGrid, Brevo, etc.)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=YOUR_SENDGRID_API_KEY

# =============================================
# Email Recipients
# =============================================
EMAIL_FROM="ASM Molfetta App <noreply@asm-molfetta.it>"
EMAIL_RECIPIENT=memiwb@gmail.com

# =============================================
# Admin Dashboard Credentials
# =============================================
# Change these before deploying to production!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ASM_Admin_2024!

# Admin session secret (any long random string)
SESSION_SECRET=asm_molfetta_super_secret_session_key_change_me
